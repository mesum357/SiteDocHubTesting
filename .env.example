# SiteViewPro — Environment Variables
# Copy this file to .env and fill in your Supabase project values.

# Frontend (Vite) — safe to expose in the browser
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Insta360 OSC (optional)
# Vite dev + preview proxy target (camera gateway). X2 default is 192.168.42.1; try 192.168.43.1 if your hotspot uses it.
INSTA360_OSC_PROXY_TARGET=http://192.168.42.1
# Browser-only: full OSC base when the app is served over http:// on camera Wi‑Fi (bypasses /api/camera). Not usable on https:// (mixed content).
# VITE_CAMERA_OSC_BASE=http://192.168.42.1

# Edge Functions only — NEVER expose in the frontend
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
